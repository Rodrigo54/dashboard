{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": ["node"],
    "paths": {
      "@shared/*": ["../../src/shared/*"],
      "@main/*": ["../../src/main/*"],
      "@renderer/*": ["../../src/renderer/*"]
    }
  },
  "include": ["**/*.ts", "../shared/**/*.ts", "../shared/**/*.d.ts"]
}
