{
  "name": "dashboard",
  "version": "0.0.0",
  "description": "Dashboard desktop app (Electron + Angular)",
  "author": "Rodrigo Alves <rodrigo54mix@gmail.com>",
  "main": "out/main/main.js",
  "scripts": {
    "ng": "ng",
    "dev": "node scripts/electron-vite.mjs dev",
    "build": "electron-vite build",
    "preview": "node scripts/electron-vite.mjs preview",
    "typecheck": "tsc -p src/main/tsconfig.json && tsc -p tsconfig.app.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\"",
    "test": "ng test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dist": "electron-vite build && electron-builder",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "@angular/cdk": "^22",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@ng-icons/core": "^33.2.3",
    "@ng-icons/lucide": "^33.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^1.0.0-beta.22",
    "lucide-angular": "^1.0.0",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.3.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.6",
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.0.0",
    "angular-eslint": "^22.0.0",
    "drizzle-kit": "^1.0.0-beta.22",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^7",
    "vitest": "^4.0.8"
  }
}
