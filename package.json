{
  "name": "dashboard",
  "version": "0.0.0",
  "description": "Dashboard desktop app (Electron + Angular)",
  "author": "Rodrigo Alves <rodrigo54mix@gmail.com>",
  "main": "dist/main/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron:build": "tsc -p src/main/tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "electron:run": "wait-on tcp:127.0.0.1:4200 && bun run electron:build && node scripts/start-electron.mjs",
    "dev": "concurrently -k -n ng,electron -c blue,green \"ng serve --host 127.0.0.1\" \"bun run electron:run\"",
    "dist": "ng build && bun run electron:build && electron-builder"
  },
  "private": true,
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "drizzle-orm": "^1.0.0-beta.22",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@types/node": "^24.0.0",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^1.0.0-beta.22",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8",
    "wait-on": "^9.0.0"
  }
}